# Copy to .env and fill in. .env is gitignored (never commit real keys).
# EODHD — required for price/return data (Prompt 5+ / the pipeline's returns step)
EODHD_API_KEY=
# OpenFIGI — OPTIONAL (basic CUSIP->ticker works without a key; a key raises the rate limit)
OPENFIGI_API_KEY=
# LLM reviewer keys — only used by tools/qa-review (the multi-prompt-build QA fan-out), NOT the pipeline
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
